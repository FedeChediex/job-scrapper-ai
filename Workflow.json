      "parameters": {
        "jsCode": "const savedLinks = new Set(\n  $('ObtenerDatosSheet').all()\n    .filter(item => item.json.Link)\n    .map(item => item.json.Link)\n);\n\nconst newJobs = $('Deduplicar busqueda').all().filter(item => {\n  return !savedLinks.has(item.json.link);\n});\n\nreturn newJobs;"
      },
