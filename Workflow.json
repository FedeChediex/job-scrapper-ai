        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  let raw = item.json.raw;\n  \n  // Limpiar backticks\n  raw = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  \n  const parsed = JSON.parse(raw);\n  if (parsed.puntaje_para_mi > 10) parsed.puntaje_para_mi = parsed.puntaje_para_mi / 10;\n  items.push({ json: parsed });\n}\n\nreturn items;"
      },
