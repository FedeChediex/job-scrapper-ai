    {
      "parameters": {
        "jsCode": "console.log('Total items:', $input.all().length);\nconsole.log('Primer item tipo:', typeof $input.all()[0].json);\nconsole.log('Primer item:', JSON.stringify($input.all()[0].json).slice(0, 200));\n\nconst allJobs = $input.all().flatMap(item => \n  Array.isArray(item.json) ? item.json : [item.json]\n);\n\nconsole.log('Total jobs aplanados:', allJobs.length);\nconst seen = new Set();\nconst items = [];\n\nfor (const job of allJobs) {\n  if (job.id && !seen.has(job.id)) {\n    seen.add(job.id);\n    items.push({ json: job });\n  }\n}\n\nreturn items;"
      },
